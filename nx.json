{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "extends": "@omnifield/nx-preset/nx.json",
  "targetDefaults": {
    "test:py": {
      "cache": true,
      "inputs": ["pythonSources", "^pythonSources"]
    },
    "lint:py": {
      "cache": true,
      "inputs": ["pythonSources"]
    }
  },
  "namedInputs": {
    "pythonSources": [
      "{projectRoot}/**/*.py",
      "{projectRoot}/pyproject.toml",
      "{projectRoot}/project.json",
      "{workspaceRoot}/pyproject.toml",
      "{workspaceRoot}/uv.lock",
      "{workspaceRoot}/.python-version"
    ]
  }
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/git-gate.mjs"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/main-session-marker.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/scope-identity.mjs"
          }
        ]
      }
    ]
  }
}

{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@brainer/agent-harness-plugin",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node test/validate.mjs",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --test test/*.test.mjs",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check .",
        "cwd": "{projectRoot}"
      }
    }
  }
}
